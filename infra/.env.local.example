# ローカル開発用環境変数テンプレート
# このファイルを .env.local にコピーして使用する
# .env.local は .gitignore に追加すること

# アプリ動作モード
ENV=local

# GCP プロジェクト (エミュレータ用ダミー値)
GCP_PROJECT_ID=actionrev-local

# Cloud Storage
GCS_BUCKET=actionrev-uploads
# STORAGE_EMULATOR_HOST は docker-compose.yml で注入済み

# BigQuery
BIGQUERY_PROJECT_ID=actionrev-local
BIGQUERY_DATASET=graph
# BIGQUERY_EMULATOR_HOST は docker-compose.yml で注入済み

# Firebase Auth
FIREBASE_PROJECT_ID=actionrev-local
# FIREBASE_AUTH_EMULATOR_HOST は docker-compose.yml で注入済み

# Vertex AI / Gemini (実際の GCP プロジェクトが必要。Gemini にエミュレータはない)
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-2.0-flash-001

# Gemini レスポンスキャッシュ
# GEMINI_CACHE_ENABLED=true の場合、プロンプトのハッシュをキーにレスポンスをファイルキャッシュする
# 同じプロンプトへの再呼び出しは Gemini API を叩かずキャッシュを返す
# キャッシュディレクトリはリポジトリルートの .gemini-cache/ (docker-compose でマウント済み)
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_DIR=/app/.gemini-cache

# Stripe (テストモードキーを使用)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# サーバー設定
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
